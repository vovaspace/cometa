{
  "name": "@cometa/core",
  "version": "0.2.1",
  "description": "The declarative state manager.",
  "sideEffects": false,
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "typings": "./lib/typings/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./lifecycle": {
      "import": "./lib/esm/lifecycle/index.js",
      "require": "./lib/cjs/lifecycle/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "jest --colors",
    "build": "npm run clean && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json",
    "clean": "rimraf ./lib",
    "code:lint": "prettier --check . && eslint .",
    "code:fix": "prettier --write . && eslint --fix ."
  },
  "license": "ISC",
  "author": "Vladimir Lewandowski <me@vovaspace.com> (https://vovaspace.com/)",
  "homepage": "https://cometa.js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/vovaspace/cometa.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/vovaspace/cometa/issues"
  },
  "keywords": [
    "state manager",
    "state management",
    "state",
    "store",
    "event",
    "effect",
    "declarative",
    "functional",
    "reactive",
    "frp"
  ]
}
