    "url": "https://github.com/vovaspace/cometa.git",
    "directory": "examples/react-server-side-rendering"
  },
  "bugs": {
    "url": "https://github.com/vovaspace/cometa/issues"
  },
  "dependencies": {
    "@babel/runtime": "^7.16.7",
    "@cometa/core": "file:../../packages/core/lib",
    "@cometa/operators": "file:../../packages/operators/lib",
    "@cometa/react": "file:../../packages/react/lib",
    "core-js": "^3.20.2",
    "express": "^4.17.1",
    "react": "18.0.0-rc.0-next-9d4e8e84f-20220207",
