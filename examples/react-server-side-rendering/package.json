  "description": "Cometa with React Server Side Rendering Example",
  "scripts": {
    "start": "npm run start:client & npm run start:server",
    "start:client": "webpack --config webpack.config.client.js --env development --watch",
    "start:server": "nodemon build/server/index.js & webpack --config webpack.config.server.js --env development --watch",
    "link": "npm link ../../node_modules/react",
    "code:lint": "prettier --check . && eslint .",
    "code:fix": "prettier --write . && eslint --fix ."
  },
